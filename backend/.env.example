# Anthropic / Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# 代理商 base URL（留空则使用官方 https://api.anthropic.com）
ANTHROPIC_BASE_URL=
# 使用的模型（留空则默认 claude-sonnet-4-6）
ANTHROPIC_MODEL=

# OpenAI (Whisper ASR + Embeddings + 智增增 provider)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=

# 阿里云通义千问 (Qwen)
# 控制台：https://dashscope.aliyun.com → API-KEY管理
DASHSCOPE_API_KEY=your_dashscope_api_key_here
# 可选模型：qwen-turbo（最便宜）/ qwen-plus（推荐）/ qwen-max
QWEN_MODEL=qwen-plus

# DeepSeek
# 控制台：https://platform.deepseek.com → API keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# 可选模型：deepseek-chat / deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# 字节跳动豆包 (Doubao)
# 控制台：https://console.volcengine.com/ark → API Key（需先开通模型）
VOLC_API_KEY=your_volc_api_key_here
# 可选模型：doubao-lite-4k（最便宜）/ doubao-pro-4k（推荐）
DOUBAO_MODEL=doubao-pro-4k

# Alibaba Cloud ASR (Chinese + English, RESTful async API)
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id_here
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret_here
ALIYUN_ASR_APP_KEY=your_aliyun_asr_app_key_here
# OSS bucket for temporary audio upload (required by Aliyun ASR)
ALIYUN_OSS_BUCKET=your_oss_bucket_name
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Production database paths
LIBERSTUDY_DB_PATH=/var/lib/liberstudy/database.db
LIBERSTUDY_LIVE_DB_PATH=/var/lib/liberstudy/live_data.db

# Google OAuth (future auth integration)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# Invite allowlist (future auth integration)
ALLOWED_GOOGLE_EMAILS=user1@gmail.com,user2@gmail.com

# Optional: public guest access for portfolio/HR review.
# When true, unauthenticated visitors automatically enter the real app as guests.
PUBLIC_GUEST_ACCESS=false

# Session cookie (future auth integration)
SESSION_SECRET=your_random_secret_key_min_32_chars
SESSION_EXPIRE_DAYS=7
# Use "none" only when frontend/backend are on different sites, e.g. vercel.app + render.com.
SESSION_COOKIE_SAMESITE=lax
